# OpenAI API Key (for embeddings and agent)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Chroma persistence directory
CONFIDENT_API_KEY=your_confident_api_key_here
CONFIDENT_TRACE_FLUSH=1

# API Configuration
PORT=8000
HOST=0.0.0.0

# --- Tenancy / auth ---
# Verify the caller's Google bearer against Google tokeninfo (and its `sub` against
# X-User-Id). ON by default; set false only for local/offline dev or tests.
MEMORY_VALIDATE_TOKEN=true
# Strict identity: reject a validated token that carries no `sub` (an API-scope-only
# gmail/calendar token). OFF by default to keep executor parity + those valid tokens
# working. Turn on (once callers send an openid-scoped token) to close X-User-Id
# spoofing now that each user has an isolated store.
MEMORY_REQUIRE_SUB=false
# Cap on resident per-user MemoryUnits (LRU-evicted past this). Bounds RAM.
MEMORY_MAX_USERS=100

# --- Shared store (write-back durability) ---
# jsonl (default, per-user file under persist_dir) or pg (shared planner.context_blocks,
# scoped by user_id). PLANNER_DATABASE_URL is required only when STORE_BACKEND=pg.
STORE_BACKEND=jsonl
# PLANNER_DATABASE_URL=postgresql://planner_app:...@host:5432/workflow_executor?sslmode=require

# Opt-in LLM value extractor for resolve() (deterministic regex/clause is the default+fallback).
MEMORY_RESOLVE_LLM=false
